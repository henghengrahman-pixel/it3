<%- include('../partials/topbar') %>

<link rel="stylesheet" href="/css/parlay-detail.css">

<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>

<main class="container parlay-layout parlay-single-layout">

  <article class="parlay-single parlay-single-pro">

    <a
      class="badge"
      href="/category/<%= String(post.category || '').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'') %>"
    >

      <%= post.category || 'Prediksi Parlay' %>

    </a>

    <h1>

      <%= post.title %>

    </h1>

    <div class="single-meta">

      <span>
        👤
        <strong>
          <%= post.author || 'Master Parlay' %>
        </strong>
      </span>

      <span>
        📅
        <%= fmtDate(post.createdAt) %>
      </span>

      <% (post.tags || []).forEach(function(tag){ %>

        <span class="meta-tag">
          #<%= tag %>
        </span>

      <% }) %>

    </div>

    <% if (post.thumbnail) { %>

      <img
        class="single-cover"
        src="<%= post.thumbnail %>"
        alt="<%= post.title %>"
        loading="lazy"
      >

    <% } %>

    <div class="article-content">

      <%- post.content %>

    </div>

    <% if (
      (post.predictions || []).length
    ) { %>

      <section class="prediction-section">

        <div class="prediction-header">

          <h2>
            Prediksi Parlay Malam Ini
          </h2>

          <p>
            Berikut pertandingan pilihan dari liga besar dunia dan Liga Indonesia yang memiliki potensi menarik untuk dijadikan referensi parlay hari ini.
          </p>

        </div>

        <% post.predictions.forEach(function(league){ %>

          <div class="prediction-table-wrap">

            <h2 class="league-title">

              <%= league.league %>

            </h2>

            <table class="prediksi-table">

              <thead>

                <tr>

                  <th>
                    <%= league.league %>
                  </th>

                  <th>
                    1X2
                  </th>

                  <th>
                    O/U
                  </th>

                  <th>
                    SKOR
                  </th>

                </tr>

              </thead>

              <tbody>

                <% league.matches.forEach(function(match){ %>

                  <tr>

                    <td class="match-team-col">

                      <div class="match-team-wrap">

                        <div class="team-row">

                          <% if (match.homeLogo) { %>

                            <img
                              src="<%= match.homeLogo %>"
                              alt="<%= match.home %>"
                              loading="lazy"
                            >

                          <% } %>

                          <span>

                            <%= match.home || match.match.split(' vs ')[0] %>

                          </span>

                        </div>

                        <div class="vs-text">
                          VS
                        </div>

                        <div class="team-row">

                          <% if (match.awayLogo) { %>

                            <img
                              src="<%= match.awayLogo %>"
                              alt="<%= match.away %>"
                              loading="lazy"
                            >

                          <% } %>

                          <span>

                            <%= match.away || match.match.split(' vs ')[1] %>

                          </span>

                        </div>

                        <% if (match.timeWib) { %>

                          <small class="match-time">

                            <%= match.timeWib %>

                          </small>

                        <% } %>

                      </div>

                    </td>

                    <td class="pick-col">

                      <strong>

                        <%= match.pick %>

                      </strong>

                      <% if (match.percentHome || match.percentAway) { %>

                        <small class="percent-text">

                          <% if (match.pick === "1") { %>

                            <%= match.percentHome %>

                          <% } else if (match.pick === "2") { %>

                            <%= match.percentAway %>

                          <% } else { %>

                            <%= match.percentDraw %>

                          <% } %>

                        </small>

                      <% } %>

                    </td>

                    <td class="ou-col">

                      <strong>

                        <%= match.ou %>

                      </strong>

                    </td>

                    <td class="score-col">

                      <strong>

                        <%= match.score %>

                      </strong>

                    </td>

                  </tr>

                <% }) %>

              </tbody>

            </table>

          </div>

        <% }) %>

      </section>

    <% } %>

    <div class="parlay-note">

      <p>

        <strong>
          Rekomendasi Prediksi Pilihan Hari Ini
        </strong>

      </p>

      <p>
        Gunakan prediksi ini sebagai tambahan referensi sebelum menentukan pilihan pertandingan. Tetap gunakan manajemen modal dengan baik dan bermain secara bijak.
      </p>

    </div>

    <% if (related.length) { %>

      <div class="related">

        <h3>
          Related Post
        </h3>

        <div class="related-grid">

          <% related.forEach(function(item){ %>

            <a href="<%= parlayUrl(item) %>">

              <%= item.title %>

            </a>

          <% }) %>

        </div>

      </div>

    <% } %>

  </article>

  <%- include('../partials/sidebar-blog', {
    latestPosts,
    ads
  }) %>

</main>

<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
