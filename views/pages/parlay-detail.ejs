<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>

<main class="container parlay-layout parlay-single-layout">

  <article class="parlay-single parlay-single-pro">

    <a
      class="badge"
      href="/category/<%= String(post.category || '').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'') %>"
    >
      <%= post.category || 'Prediksi Parlay' %>
    </a>

    <h1>
      <%= post.title %>
    </h1>

    <div class="single-meta">

      By
      <strong>
        <%= post.author || 'Master Parlay' %>
      </strong>

      •

      <%= fmtDate(post.createdAt) %>

      •

      <% (post.tags || []).forEach(function(tag){ %>

        <span>
          #<%= tag %>
        </span>

      <% }) %>

    </div>

    <% if (post.thumbnail) { %>

      <img
        class="single-cover"
        src="<%= post.thumbnail %>"
        alt="<%= post.title %>"
      >

    <% } %>

    <div class="article-content">

      <%- post.content %>

    </div>

    <% if (
      (post.predictions || []).length &&
      !post.autoGenerated
    ) { %>

      <section class="prediction-section">

        <div class="prediction-header">

          <h2>
            Prediksi Parlay Malam Ini
          </h2>

          <p>
            Berikut beberapa pertandingan pilihan dari liga utama dunia dan Liga Indonesia yang layak dipantau hari ini.
          </p>

        </div>

        <% post.predictions.forEach(function(league){ %>

          <section class="league-section">

            <div class="league-heading">

              <h2 class="league-title">
                <%= league.league %>
              </h2>

            </div>

            <div class="match-grid">

              <% league.matches.forEach(function(match, index){ %>

                <div class="match-card">

                  <div class="match-card-top">

                    <div class="match-number">

                      #<%= index + 1 %>

                    </div>

                    <% if (match.timeWib) { %>

                      <div class="match-time">

                        <%= match.timeWib %>

                      </div>

                    <% } %>

                  </div>

                  <div class="match-card-body">

                    <div class="team-row">

                      <div class="team">

                        <% if (match.homeLogo) { %>

                          <img
                            src="<%= match.homeLogo %>"
                            alt="<%= match.home %>"
                            loading="lazy"
                          >

                        <% } %>

                        <span>
                          <%= match.home || match.match.split(' vs ')[0] %>
                        </span>

                      </div>

                      <div class="vs">
                        VS
                      </div>

                      <div class="team team-away">

                        <% if (match.awayLogo) { %>

                          <img
                            src="<%= match.awayLogo %>"
                            alt="<%= match.away %>"
                            loading="lazy"
                          >

                        <% } %>

                        <span>
                          <%= match.away || match.match.split(' vs ')[1] %>
                        </span>

                      </div>

                    </div>

                    <div class="prediction-boxes">

                      <div class="pred-box">

                        <small>
                          1X2
                        </small>

                        <strong>
                          <%= match.pick %>
                        </strong>

                      </div>

                      <div class="pred-box">

                        <small>
                          O/U
                        </small>

                        <strong>
                          <%= match.ou %>
                        </strong>

                      </div>

                      <div class="pred-box">

                        <small>
                          SKOR
                        </small>

                        <strong>
                          <%= match.score %>
                        </strong>

                      </div>

                    </div>

                  </div>

                </div>

              <% }) %>

            </div>

          </section>

        <% }) %>

      </section>

    <% } %>

    <div class="parlay-note">

      <p>
        <strong>
          Rekomendasi Prediksi Pilihan Hari Ini
        </strong>
      </p>

      <p>
        Gunakan prediksi ini sebagai tambahan referensi sebelum menentukan pilihan pertandingan. Tetap gunakan manajemen modal dengan baik dan bermain secara bijak.
      </p>

    </div>

    <% if (related.length) { %>

      <div class="related">

        <h3>
          Related Post
        </h3>

        <div class="related-grid">

          <% related.forEach(function(item){ %>

            <a href="<%= parlayUrl(item) %>">

              <%= item.title %>

            </a>

          <% }) %>

        </div>

      </div>

    <% } %>

  </article>

  <%- include('../partials/sidebar-blog', { latestPosts, ads }) %>

</main>

<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
