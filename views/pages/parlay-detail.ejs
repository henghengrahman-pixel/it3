<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>

<main class="container parlay-layout parlay-single-layout">

  <article class="parlay-single parlay-single-pro">

    <a class="badge category-badge"
      href="/category/<%= String(post.category || '').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'') %>">
      <%= post.category || 'Prediksi Parlay' %>
    </a>

    <h1 class="single-title">
      <%= post.title %>
    </h1>

    <div class="single-meta">
      <span>
        By
        <strong>
          <%= post.author || 'Master Parlay' %>
        </strong>
      </span>

      <span>
        •
        <%= fmtDate(post.createdAt) %>
      </span>

      <% (post.tags || []).forEach(function(tag){ %>
        <span class="meta-tag">
          #<%= tag %>
        </span>
      <% }) %>
    </div>

    <% if (post.thumbnail) { %>
      <div class="single-cover-wrap">
        <img
          class="single-cover"
          src="<%= post.thumbnail %>"
          alt="<%= post.title %>"
        >
      </div>
    <% } %>

    <div class="article-content">
      <%- post.content %>
    </div>

    <% if ((post.predictions || []).length) { %>

      <section class="prediction-section">

        <div class="section-head">
          <h2>
            Prediksi Parlay Malam Ini
          </h2>

          <p>
            Analisa pertandingan pilihan dari liga besar dunia dengan prediksi skor, confidence, dan safe pick.
          </p>
        </div>

        <% post.predictions.forEach(function(league){ %>

          <div class="league-box">

            <div class="league-head">

              <h2 class="league-title">
                <%= league.league %>
              </h2>

              <span class="league-count">
                <%= league.matches.length %> Match
              </span>

            </div>

            <div class="table-responsive">

              <table class="prediksi-table premium-table">

                <thead>

                  <tr>
                    <th>MATCH</th>
                    <th>1X2</th>
                    <th>O/U</th>
                    <th>SKOR</th>
                    <th>ODDS</th>
                    <th>CONF</th>
                  </tr>

                </thead>

                <tbody>

                  <% league.matches.forEach(function(match){ %>

                    <tr>

                      <td class="match-cell">

                        <div class="match-name">
                          <%= match.match %>
                        </div>

                        <div class="match-badges">

                          <% if(match.safePick){ %>
                            <span class="badge safe-badge">
                              SAFE PICK
                            </span>
                          <% } %>

                          <% if(match.bigMatch){ %>
                            <span class="badge big-badge">
                              BIG MATCH
                            </span>
                          <% } %>

                          <% if(match.superBigMatch){ %>
                            <span class="badge super-badge">
                              SUPER BIG MATCH
                            </span>
                          <% } %>

                          <% if(match.hotMatch){ %>
                            <span class="badge hot-badge">
                              HOT
                            </span>
                          <% } %>

                          <% if(match.primeTime){ %>
                            <span class="badge prime-badge">
                              PRIME TIME
                            </span>
                          <% } %>

                        </div>

                      </td>

                      <td>
                        <span class="pick pick-<%= String(match.pick).toLowerCase() %>">
                          <%= match.pick %>
                        </span>
                      </td>

                      <td>
                        <span class="ou-badge">
                          <%= match.ou %>
                        </span>
                      </td>

                      <td>
                        <strong class="score-text">
                          <%= match.score %>
                        </strong>
                      </td>

                      <td>
                        <span class="odds-text">
                          <%= match.oddsEstimate || '-' %>
                        </span>
                      </td>

                      <td>

                        <div class="confidence-wrap">

                          <div class="confidence-bar">
                            <span
                              style="width:<%= match.confidence || 0 %>%"
                            ></span>
                          </div>

                          <small>
                            <%= match.confidence || 0 %>%
                          </small>

                        </div>

                      </td>

                    </tr>

                  <% }) %>

                </tbody>

              </table>

            </div>

          </div>

        <% }) %>

      </section>

    <% } %>

    <div class="parlay-note premium-note">

      <h3>
        Rekomendasi Prediksi Bola Hari Ini
      </h3>

      <p>
        Prediksi yang ditampilkan di halaman ini dibuat berdasarkan pertandingan pilihan dari liga besar dan pertandingan populer yang banyak dimainkan member setiap harinya.
      </p>

      <p>
        Gunakan prediksi ini sebagai referensi tambahan sebelum menentukan pilihan bermain. Tetap bermain secara bijak dan gunakan manajemen risiko yang aman.
      </p>

    </div>

    <% if (related.length) { %>

      <section class="related-post">

        <div class="related-head">
          <h3>
            Related Post
          </h3>
        </div>

        <div class="related-grid">

          <% related.forEach(function(item){ %>

            <a
              class="related-card"
              href="<%= parlayUrl(item) %>"
            >

              <% if(item.thumbnail){ %>
                <img
                  src="<%= item.thumbnail %>"
                  alt="<%= item.title %>"
                >
              <% } %>

              <div class="related-info">

                <h4>
                  <%= item.title %>
                </h4>

                <span>
                  <%= fmtDate(item.createdAt) %>
                </span>

              </div>

            </a>

          <% }) %>

        </div>

      </section>

    <% } %>

  </article>

  <%- include('../partials/sidebar-blog', {
    latestPosts,
    ads
  }) %>

</main>

<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
