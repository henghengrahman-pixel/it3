<div id="loader" class="loader"><div class="loader-card"><img src="<%= settings.logoUrl %>" alt="<%= settings.siteName %>" style="height:56px;border-radius:10px"/><div class="spin"></div><p>Memuat prediksi…</p></div></div>
<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>
<section class="hero"><div class="container"><h1>Analisa Pertandingan Hari Ini</h1><p id="dateLine" class="date"></p></div></section>
<main class="container" id="content"></main>
<section class="blog-wrap container">
  <div class="latest-ribbon"><span>Latest Post</span></div>
  <div class="blog-layout">
    <div class="post-list">
      <% posts.forEach(function(post){ %>
        <article class="news-card">
          <a class="news-thumb" href="/<%= post.slug %>"><img src="<%= post.thumbnail %>" alt="<%= post.title %>" loading="lazy"></a>
          <div class="news-body">
            <a class="badge" href="/category/<%= String(post.category || '').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'') %>"><%= post.category %></a>
            <h2><a href="/<%= post.slug %>"><%= post.title %></a></h2>
            <div class="post-meta">▣ <%= fmtDate(post.createdAt) %> &nbsp; ▣ <%= post.author %></div>
            <p><%= post.excerpt %></p>
          </div>
        </article>
      <% }) %>
      <div class="pagination">
        <% if (currentPage > 1) { %><a href="/?page=<%= currentPage - 1 %>">‹</a><% } %>
        <% for(let i=1; i<=totalPages; i++){ %>
          <% if (i === currentPage || i <= 2 || i === totalPages || Math.abs(i-currentPage)<=1) { %>
            <a class="<%= i === currentPage ? 'on' : '' %>" href="/?page=<%= i %>"><%= i %></a>
          <% } else if (i === 3 && currentPage > 4) { %><span>...</span><% } %>
        <% } %>
        <% if (currentPage < totalPages) { %><a href="/?page=<%= currentPage + 1 %>">›</a><% } %>
      </div>
    </div>
    <%- include('../partials/sidebar-blog', { latestPosts, ads }) %>
  </div>
</section>
<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
