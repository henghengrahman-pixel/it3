<div id="loader" class="loader">
  <div class="loader-card">

    <img
      src="<%= settings.logoUrl %>"
      alt="<%= settings.siteName %>"
      style="height:56px;border-radius:10px"
    />

    <div class="spin"></div>

    <p>Memuat live score…</p>

  </div>
</div>

<%- include('../partials/topbar') %>

<%- include('../partials/ticker') %>

<%- include('../partials/slider') %>

<%- include('../partials/auth-buttons') %>

<section class="hero">

  <div class="container">

    <h1>Live Score</h1>

    <p
      class="date"
      id="dateLine"
    ></p>

  </div>

</section>

<!-- LIVE SCORE 7M -->
<section class="container">

  <div class="panel live">

    <div class="head">
      LIVE SCORE
    </div>

    <div class="twrap">

      <div class="embed7m">

        <iframe
          id="sevenM"

          src="https://freelive-id.7msport.com/live.aspx?mark=en&TimeZone=%2B0700&wordAd=&cpageBgColor=FFFFFF&wadurl=https://nowgoalo.com&width=100%25&tableFontSize=12&cborderColor=DDDDDD&ctdColor1=FFFFFF&ctdColor2=F1FAFF&clinkColor=0000FF&cdateFontColor=FFFFFF&cdateBgColor=559EE3&scoreFontSize=12&cteamFontColor=000000&cgoalFontColor=FF0000&cgoalBgColor=FFFFE1&cremarkFontColor=000000&cremarkBgColor=F7F8F3&Skins=1&teamWeight=400&scoreWeight=700&goalWeight=400&fontWeight=700&DSTbox=&ordType=&view=All&voi=0&away=0&red=0&all=0"

          width="100%"

          height="5000"

          frameborder="0"

          loading="lazy"

          referrerpolicy="no-referrer-when-downgrade"

        ></iframe>

      </div>

    </div>

  </div>

</section>

<%- include('../partials/footer') %>

<%- include('../partials/quick-menu') %>

<script>

const $ = s => document.querySelector(s);

document.getElementById(
  'dateLine'
).textContent =

  new Date().toLocaleDateString(
    'id-ID',
    {
      weekday:'long',
      day:'2-digit',
      month:'long',
      year:'numeric'
    }
  );

/* Loader */
(function(){

  const loader =
    $('#loader');

  const f =
    document.getElementById(
      'sevenM'
    );

  loader.classList.add('show');

  f.addEventListener(
    'load',
    ()=> loader.classList.remove(
      'show'
    )
  );

  setTimeout(()=>{

    loader.classList.remove(
      'show'
    );

  },4000);

})();

</script>
