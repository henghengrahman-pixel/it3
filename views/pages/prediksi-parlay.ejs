<%- include('../partials/topbar') %>

<%- include('../partials/ticker') %>

<%- include('../partials/slider') %>

<%- include('../partials/auth-buttons') %>

<!-- BACKGROUND HOME -->
<section class="parlay-page with-home-bg">

  <!-- HERO -->
  <section class="parlay-hero">

    <div class="container">

      <h1>
        Prediksi Parlay
      </h1>

      <p>
        Update prediksi parlay malam ini
        berdasarkan liga dan pertandingan
        yang aktif hari ini.
      </p>

    </div>

  </section>

  <!-- CONTENT -->
  <main class="container parlay-layout">

    <!-- LEFT -->
    <section class="parlay-list">

      <% if (!posts.length) { %>

        <article class="parlay-empty">

          Belum ada prediksi parlay
          yang publish.

        </article>

      <% } %>

      <% posts.forEach(function(post){ %>

        <article class="parlay-card">

          <!-- THUMB -->
          <a
            class="parlay-thumb"
            href="<%= parlayUrl(post) %>"
          >

            <img
              src="<%= post.thumbnail %>"
              alt="<%= post.title %>"
              loading="lazy"
            >

          </a>

          <!-- BODY -->
          <div class="parlay-body">

            <!-- BADGE -->
            <a
              class="badge"

              href="/category/<%= String(post.category || '')
              .toLowerCase()
              .replace(/[^a-z0-9]+/g,'-')
              .replace(/^-|-$/g,'') %>"
            >

              <%= post.category || 'Prediksi Parlay' %>

            </a>

            <!-- TITLE -->
            <h2>

              <a href="<%= parlayUrl(post) %>">

                <%= post.title %>

              </a>

            </h2>

            <!-- META -->
            <div class="post-meta">

              ▣
              <%= fmtDate(post.createdAt) %>

              &nbsp;

              ▣
              <%= post.author || 'Master Parlay' %>

              &nbsp;

              ▣
              NO COMMENTS

            </div>

            <!-- EXCERPT -->
            <p>

              <%= post.excerpt %>

            </p>

          </div>

        </article>

      <% }) %>

      <!-- PAGINATION -->
      <div class="pagination">

        <% if (currentPage > 1) { %>

          <a href="/prediksi-parlay?page=<%= currentPage - 1 %>">

            ‹

          </a>

        <% } %>

        <% for(let i=1; i<=totalPages; i++){ %>

          <% if (
            i === currentPage ||
            i <= 2 ||
            i === totalPages ||
            Math.abs(i-currentPage)<=1
          ) { %>

            <a
              class="<%= i === currentPage ? 'on' : '' %>"

              href="/prediksi-parlay?page=<%= i %>"
            >

              <%= i %>

            </a>

          <% } else if (
            i === 3 &&
            currentPage > 4
          ) { %>

            <span>...</span>

          <% } %>

        <% } %>

        <% if (currentPage < totalPages) { %>

          <a href="/prediksi-parlay?page=<%= currentPage + 1 %>">

            ›

          </a>

        <% } %>

      </div>

    </section>

    <!-- SIDEBAR -->
    <%- include(
      '../partials/sidebar-blog',
      {
        latestPosts: allPosts.slice(0, 8),
        ads
      }
    ) %>

  </main>

</section>

<%- include('../partials/footer') %>

<%- include('../partials/quick-menu') %>
