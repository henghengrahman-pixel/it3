<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>

<main class="container blog-layout single-layout">

  <article class="single-post">

    <a
      class="badge"
      href="/category/<%= String(post.category || '').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'') %>"
    >
      <%= post.category %>
    </a>

    <h1>
      <%= post.title %>
    </h1>

    <div class="single-meta">

      By
      <strong>
        <%= post.author %>
      </strong>

      •

      <%= fmtDate(post.createdAt) %>

      •

      <% (post.tags || []).forEach(function(tag){ %>

        <span>
          #<%= tag %>
        </span>

      <% }) %>

    </div>

    <% if (post.thumbnail) { %>

      <img
        class="single-cover"
        src="<%= post.thumbnail %>"
        alt="<%= post.title %>"
      >

    <% } %>

    <div class="article-content">

      <%- post.content %>

    </div>

    <% if (
      (post.predictions || []).length &&
      !post.autoGenerated
    ) { %>

      <section class="prediction-section">

        <h2 class="prediction-heading">
          Saran Prediksi Parlay Malam Ini
        </h2>

        <div class="prediction-desc">
          Berikut beberapa pilihan pertandingan tambahan yang dapat dijadikan referensi sebelum menentukan kombinasi parlay hari ini.
        </div>

        <% post.predictions.forEach(function(league){ %>

          <div class="prediction-league">

            <h2 class="league-title">
              <%= league.league %>
            </h2>

            <div class="table-wrap">

              <table class="prediksi-table">

                <thead>

                  <tr>

                    <th>No</th>

                    <th>
                      Pertandingan
                    </th>

                    <th>
                      1X2
                    </th>

                    <th>
                      O/U
                    </th>

                    <th>
                      Skor
                    </th>

                  </tr>

                </thead>

                <tbody>

                  <% league.matches.forEach(function(match, index){ %>

                    <tr>

                      <td>
                        <%= index + 1 %>
                      </td>

                      <td class="match-column">

                        <strong>
                          <%= match.match %>
                        </strong>

                        <% if (match.timeWib) { %>

                          <br>

                          <small>
                            <%= match.timeWib %>
                          </small>

                        <% } %>

                      </td>

                      <td>
                        <%= match.pick %>
                      </td>

                      <td>
                        <%= match.ou %>
                      </td>

                      <td>
                        <%= match.score %>
                      </td>

                    </tr>

                  <% }) %>

                </tbody>

              </table>

            </div>

          </div>

        <% }) %>

      </section>

    <% } %>

    <% if (related.length) { %>

      <div class="related">

        <h3>
          Related Post
        </h3>

        <div class="related-grid">

          <% related.forEach(function(item){ %>

            <a href="/<%= item.slug %>">

              <%= item.title %>

            </a>

          <% }) %>

        </div>

      </div>

    <% } %>

  </article>

  <%- include('../partials/sidebar-blog', { latestPosts, ads }) %>

</main>

<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
