<div class="admin-shell"><%- include('partials/sidebar') %><main class="admin-main"><h1>Kelola Slides</h1><div class="admin-card"><h2>Tambah Slide</h2><form class="admin-form-grid" method="post" action="/admin/slides"><label>Title<input name="title" required /></label><label>Image URL<input name="image" required /></label><label>Link<input name="link" required /></label><label>Order<input type="number" name="order" value="1" required /></label><label class="checkbox"><input type="checkbox" name="active" checked /> Active</label><button class="admin-btn" type="submit">Tambah Slide</button></form></div><% slides.forEach(function(item){ %><div class="admin-card"><form class="admin-form-grid" method="post" action="/admin/slides/<%= item.id %>/update"><label>ID<input value="<%= item.id %>" disabled /></label><label>Title<input name="title" value="<%= item.title %>" required /></label><label>Image URL<input name="image" value="<%= item.image %>" required /></label><label>Link<input name="link" value="<%= item.link %>" required /></label><label>Order<input type="number" name="order" value="<%= item.order %>" required /></label><label class="checkbox"><input type="checkbox" name="active" <%= item.active ? 'checked' : '' %> /> Active</label><div class="admin-actions-row"><button class="admin-btn" type="submit">Simpan</button></div></form><form method="post" action="/admin/slides/<%= item.id %>/delete" onsubmit="return confirm('Hapus slide ini?')"><button class="admin-btn danger" type="submit">Hapus</button></form></div><% }) %></main></div>
