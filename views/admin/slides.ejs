<div class="admin-shell"><%- include('_sidebar') %><main class="admin-main"><h1>Kelola Slides</h1><div class="admin-card"><h2>Tambah Slide</h2><form class="admin-form-grid" method="post" action="/admin/slides" enctype="multipart/form-data"><label>Title<input name="title" /></label><label>Image URL<input name="image" /></label><label>Upload Gambar<input type="file" name="imageFile" accept="image/*" /></label><label>Link<input name="link" /></label><label>Order<input type="number" name="order" value="1" /></label><label class="checkbox"><input type="checkbox" name="active" checked /> Active</label><button class="admin-btn" type="submit">Tambah Slide</button></form></div><% slides.forEach(function(item){ %><div class="admin-card"><form class="admin-form-grid" method="post" action="/admin/slides/<%= item.id %>/update" enctype="multipart/form-data"><label>ID<input value="<%= item.id %>" disabled /></label><label>Title<input name="title" value="<%= item.title || '' %>" /></label><label>Image URL<input name="image" value="<%= item.image || '' %>" /></label><label>Upload Gambar<input type="file" name="imageFile" accept="image/*" /></label><label>Link<input name="link" value="<%= item.link || '' %>" /></label><label>Order<input type="number" name="order" value="<%= item.order || 0 %>" /></label><label class="checkbox"><input type="checkbox" name="active" <%= item.active !== false ? 'checked' : '' %> /> Active</label><button class="admin-btn" type="submit">Simpan</button></form><form method="post" action="/admin/slides/<%= item.id %>/delete" onsubmit="return confirm('Hapus slide ini?')"><button class="admin-btn danger" type="submit">Hapus</button></form></div><% }) %></main></div>
