<div class="admin-shell">
  <%- include('partials/sidebar') %>
  <main class="admin-main">
    <div class="admin-title-row">
      <h1>Kelola Posts / Berita</h1>
      <a class="admin-btn" href="/admin/posts/new">+ Tambah Post</a>
    </div>
    <div class="admin-card">
      <ul class="admin-list post-list-admin">
        <% if (!posts.length) { %><li><strong>Belum ada post</strong><span></span></li><% } %>
        <% posts.forEach(function(post){ %>
          <li>
            <div>
              <strong><%= post.title %></strong>
              <div class="k">/prediksi-parlay/<%= post.slug %> • <%= post.category %> • <%= post.published ? 'Publish' : 'Draft' %></div>
            </div>
            <div class="admin-actions-row">
              <a class="admin-btn ghost" href="/prediksi-parlay/<%= post.slug %>" target="_blank">View</a>
              <a class="admin-btn" href="/admin/posts/<%= post.id %>/edit">Edit</a>
              <form method="post" action="/admin/posts/<%= post.id %>/delete" onsubmit="return confirm('Hapus post ini?')"><button class="admin-btn danger" type="submit">Hapus</button></form>
            </div>
          </li>
        <% }) %>
      </ul>
    </div>
  </main>
</div>
