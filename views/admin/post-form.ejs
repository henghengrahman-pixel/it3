<div class="admin-shell">
  <%- include('partials/sidebar') %>
  <main class="admin-main">
    <h1><%= post ? 'Edit Post' : 'Tambah Post' %></h1>
    <form class="admin-card admin-form-grid" method="post" enctype="multipart/form-data" action="<%= post ? '/admin/posts/' + post.id + '/update' : '/admin/posts' %>">
      <label class="full">Judul Post<input name="title" value="<%= post?.title || '' %>" required></label>
      <label>Slug URL<input name="slug" value="<%= post?.slug || '' %>" placeholder="otomatis kalau dikosongkan"></label>
      <label>Kategori<input name="category" value="<%= post?.category || 'Prediksi Parlay' %>"></label>
      <label>Author<input name="author" value="<%= post?.author || 'Master Parlay' %>"></label>
      <label>Tanggal<input type="datetime-local" name="createdAt" value="<%= post?.createdAt ? new Date(post.createdAt).toISOString().slice(0,16) : '' %>"></label>
      <label>Tags pisah koma<input name="tags" value="<%= (post?.tags || []).join(', ') %>" placeholder="Betting Bola, Prediksi Bola"></label>
      <label>Thumbnail URL<input name="thumbnailUrl" value="<%= post?.thumbnail || '' %>" placeholder="https://..."></label>
      <label>Upload Thumbnail<input type="file" name="thumbnailFile" accept="image/*"></label>
      <label class="full">Excerpt<textarea name="excerpt" rows="3"><%= post?.excerpt || '' %></textarea></label>
      <label class="full">Isi Artikel HTML<textarea name="content" rows="12" placeholder="<p>Isi artikel...</p>"><%= post?.content || '' %></textarea></label>
      <label class="full">Data Prediksi JSON<textarea name="predictions" rows="16"><%= predictionsText %></textarea></label>
      <label class="checkbox"><input type="checkbox" name="published" <%= !post || post.published ? 'checked' : '' %>> Publish</label>
      <div class="admin-actions-row full"><button class="admin-btn" type="submit">Simpan Post</button><a class="admin-btn ghost" href="/admin/posts">Kembali</a></div>
    </form>
  </main>
</div>
