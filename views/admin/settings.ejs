<div class="admin-shell"><%- include('partials/sidebar') %><main class="admin-main"><h1>Site Settings</h1><div class="admin-card"><form class="admin-form-grid" method="post" action="/admin/settings"><label>Site Name<input name="siteName" value="<%= settings.siteName %>" required /></label><label>Login URL<input name="loginUrl" value="<%= settings.loginUrl %>" required /></label><label>Register URL<input name="registerUrl" value="<%= settings.registerUrl %>" required /></label><label>Logo URL<input name="logoUrl" value="<%= settings.logoUrl %>" required /></label><label>Footer Text<input name="footerText" value="<%= settings.footerText %>" required /></label><label>Meta Title<input name="metaTitle" value="<%= settings.metaTitle %>" required /></label><label class="full">Meta Description<textarea name="metaDescription" rows="4" required><%= settings.metaDescription %></textarea></label><label class="full">Running Text<textarea name="runningText" rows="4" required><%= settings.runningText %></textarea></label><button class="admin-btn" type="submit">Simpan Settings</button></form></div></main></div>
