<div class="admin-shell"><%- include('_sidebar') %><main class="admin-main"><h1>Kelola Quick Actions</h1><div class="admin-card"><h2>Tambah Quick Action</h2><form class="admin-form-grid" method="post" action="/admin/quick-actions" enctype="multipart/form-data"><label>Title<input name="title" /></label><label>Icon / Image URL<input name="icon" /></label><label>Upload Icon<input type="file" name="iconFile" accept="image/*" /></label><label>Link<input name="link" /></label><label>Warna<input name="color" placeholder="#ffd86b" /></label><label>Order<input type="number" name="order" value="1" /></label><label class="checkbox"><input type="checkbox" name="active" checked /> Active</label><button class="admin-btn" type="submit">Tambah Item</button></form></div><% quickActions.forEach(function(item){ %><div class="admin-card"><form class="admin-form-grid" method="post" action="/admin/quick-actions/<%= item.id %>/update" enctype="multipart/form-data"><label>ID<input value="<%= item.id %>" disabled /></label><label>Title<input name="title" value="<%= item.title || '' %>" /></label><label>Icon URL<input name="icon" value="<%= item.icon || '' %>" /></label><label>Upload Icon<input type="file" name="iconFile" accept="image/*" /></label><label>Link<input name="link" value="<%= item.link || '' %>" /></label><label>Warna<input name="color" value="<%= item.color || '' %>" /></label><label>Order<input type="number" name="order" value="<%= item.order || 0 %>" /></label><label class="checkbox"><input type="checkbox" name="active" <%= item.active !== false ? 'checked' : '' %> /> Active</label><button class="admin-btn" type="submit">Simpan</button></form><form method="post" action="/admin/quick-actions/<%= item.id %>/delete" onsubmit="return confirm('Hapus quick action ini?')"><button class="admin-btn danger" type="submit">Hapus</button></form></div><% }) %></main></div>
