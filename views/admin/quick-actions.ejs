<div class="admin-shell"><%- include('partials/sidebar') %><main class="admin-main"><h1>Kelola Quick Actions</h1><div class="admin-card"><h2>Tambah Quick Action</h2><form class="admin-form-grid" method="post" action="/admin/quick-actions"><label>Title<input name="title" required /></label><label>Icon / Image URL<input name="icon" required /></label><label>Link<input name="link" required /></label><label>Order<input type="number" name="order" value="1" required /></label><label class="checkbox"><input type="checkbox" name="active" checked /> Active</label><button class="admin-btn" type="submit">Tambah Item</button></form></div><% quickActions.forEach(function(item){ %><div class="admin-card"><form class="admin-form-grid" method="post" action="/admin/quick-actions/<%= item.id %>/update"><label>ID<input value="<%= item.id %>" disabled /></label><label>Title<input name="title" value="<%= item.title %>" required /></label><label>Icon URL<input name="icon" value="<%= item.icon %>" required /></label><label>Link<input name="link" value="<%= item.link %>" required /></label><label>Order<input type="number" name="order" value="<%= item.order %>" required /></label><label class="checkbox"><input type="checkbox" name="active" <%= item.active ? 'checked' : '' %> /> Active</label><div class="admin-actions-row"><button class="admin-btn" type="submit">Simpan</button></div></form><form method="post" action="/admin/quick-actions/<%= item.id %>/delete" onsubmit="return confirm('Hapus quick action ini?')"><button class="admin-btn danger" type="submit">Hapus</button></form></div><% }) %></main></div>
