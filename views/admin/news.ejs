<div class="admin-shell"><%- include('_sidebar') %><main class="admin-main"><div class="admin-topline"><h1>Semua Berita</h1><a class="admin-btn" href="/admin/news/new">Tambah Berita</a></div><div class="admin-card"><ul class="admin-list"><% if(!news.length){ %><li><strong>Belum ada berita</strong><span>Tambah artikel baru</span></li><% } %><% news.forEach(function(item){ %><li><strong><%= item.title %></strong><span><%= item.status %></span><div class="admin-actions-row"><a class="admin-btn ghost" href="/admin/news/<%= item.id %>/edit">Edit</a><form method="post" action="/admin/news/<%= item.id %>/delete" onsubmit="return confirm('Hapus berita ini?')"><button class="admin-btn danger" type="submit">Hapus</button></form></div></li><% }) %></ul></div></main></div>
