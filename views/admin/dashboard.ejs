<div class="admin-shell"><%- include('_sidebar') %><main class="admin-main"><h1>Dashboard</h1><div class="admin-grid stats"><div class="admin-card"><div class="k">Slides</div><div class="v"><%= slides.length %></div></div><div class="admin-card"><div class="k">Quick Actions</div><div class="v"><%= quickActions.length %></div></div><div class="admin-card"><div class="k">Berita</div><div class="v"><%= news.length %></div></div></div><div class="admin-grid two"><div class="admin-card"><h2>Slides Aktif</h2><ul class="admin-list"><% slides.forEach(function(item){ %><li><strong><%= item.title %></strong><span>#<%= item.order %></span></li><% }) %></ul></div><div class="admin-card"><h2>Berita Terbaru</h2><ul class="admin-list"><% news.slice(0,6).forEach(function(item){ %><li><strong><%= item.title %></strong><span><%= item.status %></span></li><% }) %></ul></div></div></main></div>
