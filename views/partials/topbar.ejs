<header class="topbar">
  <div class="container wrap">
    <% const brandName = settings.siteName || 'Prediksi Bola'; %>
    <% if (activePage === 'home') { %>
      <button class="brand" id="logoBtn" aria-label="<%= brandName %>">
        <% if (settings.logoUrl) { %><img class="logo" src="<%= settings.logoUrl %>" alt="<%= brandName %>"><% } else { %><span class="brand-text"><%= brandName %></span><% } %>
      </button>
    <% } else { %>
      <a class="brand" href="/" aria-label="<%= brandName %>">
        <% if (settings.logoUrl) { %><img class="logo" src="<%= settings.logoUrl %>" alt="<%= brandName %>"><% } else { %><span class="brand-text"><%= brandName %></span><% } %>
      </a>
    <% } %>
    <div class="searchbox"><input id="q" type="search" placeholder="Cari liga atau tim..." aria-label="Cari liga atau tim" /><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79L20 21.5 21.5 20l-6-6Zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14Z"/></svg></div>
  </div>
</header>
